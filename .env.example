# --- Environment ---
ENV=local

# --- Feature flags ---
USE_LLM=0
ENABLE_TELEGRAM=0
ENABLE_GMAIL_DRAFT=1

# --- Batch behavior ---
PROCESS_ONLY_STATUS=
MAX_ROWS_PER_RUN=50
DRY_RUN=0

# --- Paths ---
SECRETS_DIR=secrets
ARTIFACTS_DIR=artifacts

# --- Google ---
GOOGLE_CREDENTIALS_JSON_PATH=secrets/credentials.json
GMAIL_TOKEN_JSON_PATH=secrets/gmail_token.json

# --- Google Drive ---
GOOGLE_DRIVE_ENABLED=1
DRIVE_FOLDER_CV=QJOE_CV
DRIVE_FOLDER_COVER=QJOE_COVER

# --- Telegram ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- LLM ---
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=800
OPENAI_TEMPERATURE=0.2

# --- Lock ---
LOCK_PATH=/tmp/qjoe.lock~# --- Environment ---
